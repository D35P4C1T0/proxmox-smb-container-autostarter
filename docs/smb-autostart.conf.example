# SMB Container Autostart Configuration
# Copy this file to /etc/smb-autostart.conf and customize

# TrueNAS VM Configuration
TRUENAS_VMID=110
TRUENAS_IP="192.168.1.100"

# SMB Share Configuration
SMB_SHARE_NAME="media"
CREDENTIALS_FILE="/root/.smbcredentials"

# Container Configuration
CONTAINER_CONFIG_DIR="/etc/pve/lxc"

# Timeout Configuration (in seconds)
VM_MAX_WAIT=300              # Maximum wait time for TrueNAS VM to start
SMB_MAX_WAIT=300            # Maximum wait time for SMB shares to become available
NETWORK_MAX_WAIT=60         # Maximum wait time for container network readiness
SLEEP_INTERVAL=5            # Check interval in seconds

# Network Check Configuration
NETWORK_CHECK_TARGET="8.8.8.8"  # Target for network connectivity check

# Logging Configuration
LOG_FILE="/var/log/smb-autostart.log"

